{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Missy",
  "version": "0.1.0",
  "identifier": "app.missy.desktop",
  "build": {
    "beforeDevCommand": "npm run web:react",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "npm run web:react:build",
    "frontendDist": "../web-react/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Missy",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
